# ── Required ───────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/parking_system?retryWrites=true&w=majority
JWT_SECRET=change_this_to_a_very_long_random_secret_at_least_32_chars
NODE_ENV=production
PORT=5000

# ── Optional ───────────────────────────────────────────
# Only needed if frontend is on a different domain (not needed for monorepo deploy)
# FRONTEND_URL=https://your-app.railway.app
JWT_EXPIRES_IN=24h
